<Page x:Class="пр_29.Pages.Clubs.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:пр_29.Pages.Clubs"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid Margin="20" Background="White" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхние кнопки навигации с отступом сверху -->
        <Button x:Name="BtnClubs" Content="Клубы" Width="100" Margin="10,30,650,10" 
                Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White"/>
        <Button x:Name="BtnUsers" Content="Пользователи" Width="100" 
                Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" Margin="140,30,520,10"/>

        <!-- Основной контент -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка с иконкой и кнопкой добавить -->
            <StackPanel VerticalAlignment="Top" Margin="0,0,20,0">
                <Image Width="80" Height="80" Source="/Images/ic-club.png" Margin="0,0,0,10"/>
                <Button x:Name="BthAdd" Content="Добавить" Width="100" Height="30" 
                        Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" Click="AddClub"/>
            </StackPanel>

            <!-- Правая колонка с полями ввода -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Наименование -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                    <Label Content="Наименование:" Margin="0,0,0,5" Padding="0"/>
                    <TextBox x:Name="Name" Height="25" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Время работы (правая колонка) -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
                    <Label Content="Время работы:" Margin="0,0,0,5" Padding="0" Width="283"/>
                    <TextBox x:Name="WorkTime" Height="96" VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True" Width="293"/>
                </StackPanel>

                <!-- Адрес (под наименованием, как было в оригинале) -->
                <Label Content="Адрес:" Grid.Row="0" Grid.Column="0" Padding="0" Margin="0,58,15,58"/>
                <TextBox x:Name="Address" Grid.Row="0" Grid.Column="0" Height="25" 
                         VerticalContentAlignment="Center" Margin="-1,79,15,28"/>
            </Grid>
        </Grid>
    </Grid>
</Page>