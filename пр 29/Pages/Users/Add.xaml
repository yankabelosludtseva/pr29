<Page x:Class="пр_29.Pages.Users.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:пр_29.Pages.Users"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхние кнопки навигации -->
        <Button x:Name="BtnClubs" Content="Клубы" Width="100" Margin="10,30,650,10" 
                Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White"/>
        <Button x:Name="BtnUsers" Content="Пользователи" Width="100" 
                Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" Margin="140,30,520,10"/>

        <!-- Основной контент -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка -->
            <StackPanel VerticalAlignment="Top" Margin="0,0,20,0">
                <Image x:Name="IconImage" Width="80" Height="80" Source="/Images/ic-user.png" Margin="0,0,0,10"/>
                <!-- Исправлено: Click="AddUser" вместо "AddRental" -->
                <Button x:Name="BtAdd" Content="Добавить" Width="100" Height="30" 
                        Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" Click="AddUser"/>
            </StackPanel>

            <!-- Правая колонка с полями ввода -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Дата аренды -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                    <Label Content="Дата аренды:" Margin="0,0,0,5" Padding="0"/>
                    <!-- Убраны проблемные привязки -->
                    <DatePicker x:Name="RentStart" Height="25" Width="296" 
                                FirstDayOfWeek="Monday"/>
                </StackPanel>

                <!-- Продолжительность -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
                    <Label Content="Продолжительность:" Margin="0,0,0,5" Padding="0"/>
                    <TextBox x:Name="Duration" Height="25" Width="310" 
                             Text="2" VerticalContentAlignment="Center" PreviewTextInput="NumberValidationTextBox"/>
                </StackPanel>

                <!-- Время аренды -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                    <Label Content="Время аренды:" Margin="0,0,0,5" Padding="0"/>
                    <TextBox x:Name="RentTime" Height="25" Width="295" 
                             Text="18:00" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Клуб - ИСПРАВЛЕНО: x:Name="Clubs" вместо "Club" -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                    <Label Content="Клуб:" Margin="0,0,0,5" Padding="0"/>
                    <ComboBox x:Name="Clubs" Height="25" Width="310"/>
                </StackPanel>

                <!-- ФИО -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
                    <Label Content="ФИО:" Margin="0,0,0,5" Padding="0"/>
                    <TextBox x:Name="FIO" Height="25" Width="621" 
                             Text="Иванов Иван Иванович" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>